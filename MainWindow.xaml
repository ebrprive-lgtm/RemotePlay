<Window x:Class="RemotePlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="RemotePlay"
        Icon="pack://application:,,,/Assets/RemotePlay.ico"
        Background="#111111"
        WindowStyle="SingleBorderWindow"
        WindowState="Normal"
        Width="900" Height="620"
        ResizeMode="CanResize"
        PreviewKeyDown="OnWindowPreviewKeyDown">

    <Window.Resources>
        <!-- Tab header style -->
        <Style x:Key="DarkTab" TargetType="TabItem">
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Tab" Background="#1a1a2e" Padding="16,8" Margin="0,0,2,0">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Tab" Property="Background" Value="#0d0d1a"/>
                                <Setter Property="Foreground" Value="#E94560"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Tab" Property="Background" Value="#252540"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Settings category sidebar button style -->
        <Style x:Key="SettingsCatBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1a2035"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBox style -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="Foreground" Value="#EEE"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#1e1e2e"/>
                        <Setter Property="Foreground" Value="#EEE"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#2d2d4e"/>
                                <Setter Property="Foreground" Value="#E94560"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Foreground="{TemplateBinding Foreground}"
                                          Padding="{TemplateBinding Padding}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" Margin="{TemplateBinding Padding}"
                                                                  VerticalAlignment="Center"/>
                                                <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="#888" VerticalAlignment="Center"
                                                      HorizontalAlignment="Center" Margin="0,0,4,0"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,6,24,6"
                                              VerticalAlignment="Center"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <Border Background="#1e1e2e" BorderBrush="#444" BorderThickness="1"
                                            CornerRadius="0,0,3,3">
                                        <ScrollViewer>
                                            <StackPanel IsItemsHost="True"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#111111">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- toolbar -->
            <RowDefinition Height="*"/>     <!-- content -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar ── -->
        <Border x:Name="AppToolbar" Grid.Row="0" Background="#1a1a2e" Padding="8,6">
            <DockPanel>
                <TextBlock Text="🎬 RemotePlay" Foreground="#E94560" FontSize="16"
                           FontWeight="Bold" VerticalAlignment="Center" Margin="4,0,16,0"/>
                <TextBlock x:Name="ServerStatusText" Foreground="#AAAAAA" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button x:Name="ToggleViewBtn" Content="▶  Switch to Video"
                            Click="OnToggleView"
                            Background="#E94560" Foreground="White" BorderThickness="0"
                            Padding="10,4" Margin="4,0" Cursor="Hand"/>
                    <Button Content="🔄  Refresh Log" Click="OnRefreshLog"
                            Background="#333" Foreground="White" BorderThickness="0"
                            Padding="10,4" Margin="4,0" Cursor="Hand"/>
                    <Button Content="🌐  Test Port" Click="OnTestPort"
                            Background="#333" Foreground="White" BorderThickness="0"
                            Padding="10,4" Margin="4,0" Cursor="Hand"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Tab control (debug mode) ── -->
        <TabControl x:Name="MainTabs" Grid.Row="1"
                    Background="#111111" BorderThickness="0"
                    TabStripPlacement="Top">

            <!-- ── STATUS / LOG tab ── -->
            <TabItem Header="📋  Status" Style="{StaticResource DarkTab}">
                <Grid Background="#111111">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Info bar -->
                    <Border Grid.Row="0" Background="#0d0d1a" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="IpAddressText" Foreground="#00D4AA" FontSize="16"
                                           FontWeight="Bold" TextWrapping="Wrap"/>
                                <TextBlock x:Name="AlternateUrlText" Foreground="#888" FontSize="12"
                                           Margin="0,4,0,0" TextWrapping="Wrap"/>
                                <TextBlock x:Name="MoviesPathText" Foreground="#888" FontSize="11"
                                           Margin="0,4,0,0" TextWrapping="Wrap"/>
                                <TextBlock x:Name="DiagText" Foreground="#FFAA00" FontSize="11"
                                           Margin="0,4,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0" HorizontalAlignment="Right">
                                <Image x:Name="SetupQrImage" Width="112" Height="112" Stretch="Uniform"/>
                                <TextBlock Text="Scan to open" Foreground="#888" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Log output -->
                    <Border Grid.Row="1" Background="#0a0a0a" Margin="8" CornerRadius="4"
                            BorderBrush="#333" BorderThickness="1">
                        <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                            <TextBox x:Name="LogBox"
                                     Background="Transparent" Foreground="#CCCCCC"
                                     FontFamily="Consolas" FontSize="12"
                                     IsReadOnly="True" TextWrapping="Wrap"
                                     BorderThickness="0" Padding="8"
                                     VerticalAlignment="Top"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ── SETTINGS tab ── -->
            <TabItem Header="⚙️  Settings" Style="{StaticResource DarkTab}">
                <Grid Background="#111111">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left sidebar -->
                    <Border Grid.Column="0" Background="#0d0d1a" BorderBrush="#2a2a3e" BorderThickness="0,0,1,0">
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="SETTINGS" Foreground="#555" FontSize="10" FontWeight="Bold"
                                       Margin="16,0,0,10"/>
                            <Button x:Name="SettingsCatLibrary"   Content="📁  Library"         Click="OnSettingsCat" Tag="Library"   Style="{StaticResource SettingsCatBtn}" Background="#1a2a3a" Foreground="#E94560"/>
                            <Button x:Name="SettingsCatServer"    Content="🌐  Server"          Click="OnSettingsCat" Tag="Server"    Style="{StaticResource SettingsCatBtn}"/>
                            <Button x:Name="SettingsCatPlayback"  Content="▶  Playback"         Click="OnSettingsCat" Tag="Playback"  Style="{StaticResource SettingsCatBtn}"/>
                            <Button x:Name="SettingsCatTracks"    Content="🎵  Audio &amp; Subs"   Click="OnSettingsCat" Tag="Tracks"    Style="{StaticResource SettingsCatBtn}"/>
                            <Button x:Name="SettingsCatDisplay"   Content="🖥  Display"          Click="OnSettingsCat" Tag="Display"   Style="{StaticResource SettingsCatBtn}"/>
                        </StackPanel>
                    </Border>

                    <!-- Right content area -->
                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Background="#111111">
                        <StackPanel Margin="28,24,28,24">

                            <!-- Feedback banner (shared) -->
                            <TextBlock x:Name="SettingsFeedback" Foreground="#00D4AA"
                                       FontSize="12" Margin="0,0,0,16"
                                       Visibility="Collapsed" TextWrapping="Wrap"/>

                            <!-- ── LIBRARY panel ── -->
                            <StackPanel x:Name="PanelLibrary" Visibility="Visible">
                                <TextBlock Text="Library" Foreground="#E94560" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Foreground="#666" FontSize="11" Margin="0,0,0,20"
                                           Text="The folder scanned for video files (.mp4 .mkv .avi .mov .wmv .m4v .ts .flv). All subfolders are included."/>

                                <TextBlock Text="Movies Folder" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="MoviesFolderBox" Grid.Column="0"
                                             Background="#1e1e2e" Foreground="#EEE"
                                             BorderBrush="#444" BorderThickness="1"
                                             Padding="8,6" FontSize="13"
                                             VerticalContentAlignment="Center"/>
                                    <Button Grid.Column="1" Content="Browse…" Click="OnBrowseFolder"
                                            Background="#333" Foreground="White" BorderThickness="0"
                                            Padding="12,6" Margin="8,0,0,0" Cursor="Hand"/>
                                </Grid>

                                <Button Content="Apply &amp; Restart Server" Click="OnApplySettings"
                                        Background="#E94560" Foreground="White" BorderThickness="0"
                                        Padding="14,8" HorizontalAlignment="Left" Cursor="Hand"/>
                            </StackPanel>

                            <!-- ── SERVER panel ── -->
                            <StackPanel x:Name="PanelServer" Visibility="Collapsed">
                                <TextBlock Text="Server" Foreground="#E94560" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Foreground="#666" FontSize="11" Margin="0,0,0,20"
                                           Text="Configure the web interface port and HTTPS settings."/>

                                <TextBlock Text="Port" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PortBox" Grid.Column="0"
                                             Background="#1e1e2e" Foreground="#EEE"
                                             BorderBrush="#444" BorderThickness="1"
                                             Padding="8,6" FontSize="13"
                                             VerticalContentAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Foreground="#555" FontSize="11"
                                               VerticalAlignment="Center" Margin="12,0,0,0"
                                               Text="(1024 – 65535)"/>
                                </Grid>

                                <CheckBox x:Name="UseHttpsBox"
                                          Content="Use secure HTTPS (recommended for mobile PWA)"
                                          Foreground="#EEE" FontSize="13" Margin="0,12,0,6"/>
                                <TextBlock Foreground="#555" FontSize="11" Margin="0,0,0,20" TextWrapping="Wrap"
                                           Text="HTTPS lets mobile browsers install RemotePlay as a PWA. First-time setup may require running as administrator. Browsers may prompt you to trust the local certificate."/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <Button Content="Export HTTPS Certificate" Click="OnExportCertificate"
                                            Background="#333" Foreground="White" BorderThickness="0"
                                            Padding="12,6" Cursor="Hand"/>
                                    <Button Content="Open Health Page" Click="OnOpenHealthPage"
                                            Background="#333" Foreground="White" BorderThickness="0"
                                            Padding="12,6" Margin="8,0,0,0" Cursor="Hand"/>
                                </StackPanel>

                                <Button Content="Apply &amp; Restart Server" Click="OnApplySettings"
                                        Background="#E94560" Foreground="White" BorderThickness="0"
                                        Padding="14,8" HorizontalAlignment="Left" Cursor="Hand"/>
                            </StackPanel>

                            <!-- ── PLAYBACK panel ── -->
                            <StackPanel x:Name="PanelPlayback" Visibility="Collapsed">
                                <TextBlock Text="Playback" Foreground="#E94560" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Foreground="#666" FontSize="11" Margin="0,0,0,20"
                                           Text="Default behaviour when a video finishes playing."/>

                                <TextBlock Text="When a video ends" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <ComboBox x:Name="PlaybackEndBehaviorCombo"
                                          Style="{StaticResource DarkComboBox}"
                                          HorizontalAlignment="Left" MinWidth="220" Margin="0,0,0,20">
                                    <ComboBoxItem Content="Stop playback" Tag="Stop"/>
                                    <ComboBoxItem Content="Play next video automatically" Tag="PlayNext"/>
                                    <ComboBoxItem Content="Return to library" Tag="ReturnToLibrary"/>
                                </ComboBox>

                                <TextBlock Text="Playback history limit" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PlaybackHistoryLimitBox" Grid.Column="0"
                                             Background="#1e1e2e" Foreground="#EEE"
                                             BorderBrush="#444" BorderThickness="1"
                                             Padding="8,6" FontSize="13"
                                             VerticalContentAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Foreground="#555" FontSize="11"
                                               VerticalAlignment="Center" Margin="12,0,0,0"
                                               Text="Maximum number of movies kept in Continue Watching / recent history."/>
                                </Grid>

                                <Button Content="Apply &amp; Restart Server" Click="OnApplySettings"
                                        Background="#E94560" Foreground="White" BorderThickness="0"
                                        Padding="14,8" HorizontalAlignment="Left" Cursor="Hand"/>
                            </StackPanel>

                            <!-- ── AUDIO & SUBS panel ── -->
                            <StackPanel x:Name="PanelTracks" Visibility="Collapsed">
                                <TextBlock Text="Audio &amp; Subtitles" Foreground="#E94560" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Foreground="#666" FontSize="11" Margin="0,0,0,20" TextWrapping="Wrap"
                                           Text="Language preferences applied automatically when a video starts."/>

                                <TextBlock Text="Audio" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,22">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="240"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Preferred language" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="PreferredAudioLangCombo" Grid.Column="1"
                                              Style="{StaticResource DarkComboBox}"/>
                                    <TextBlock Grid.Column="2" Foreground="#555" FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"
                                               Text="Blank uses the default audio track."/>
                                </Grid>

                                <TextBlock Text="Subtitles" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="240"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Primary language" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="PreferredSubtitleLangCombo" Grid.Column="1"
                                              Style="{StaticResource DarkComboBox}"/>
                                    <TextBlock Grid.Column="2" Foreground="#555" FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"
                                               Text="Tried first when matching subtitle tracks."/>
                                </Grid>

                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="240"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Secondary language" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="SecondarySubtitleLangCombo" Grid.Column="1"
                                              Style="{StaticResource DarkComboBox}"/>
                                    <TextBlock Grid.Column="2" Foreground="#555" FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"
                                               Text="Optional fallback if the primary subtitle language is unavailable."/>
                                </Grid>

                                <CheckBox x:Name="PreferForcedSubtitlesBox"
                                          Content="Prefer forced subtitle tracks (dialogue subtitles for foreign language portions)"
                                          Foreground="#EEE" FontSize="13" Margin="0,0,0,24"/>

                                <Button Content="Apply &amp; Restart Server" Click="OnApplySettings"
                                        Background="#E94560" Foreground="White" BorderThickness="0"
                                        Padding="14,8" HorizontalAlignment="Left" Cursor="Hand"/>
                            </StackPanel>

                                            <!-- ── DISPLAY panel ── -->
                                            <StackPanel x:Name="PanelDisplay" Visibility="Collapsed">
                                                <TextBlock Text="Display" Foreground="#E94560" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
                                                <TextBlock Foreground="#666" FontSize="11" Margin="0,0,0,20" TextWrapping="Wrap"
                                                           Text="Choose which monitor the fullscreen video window opens on."/>

                                                <TextBlock Text="Fullscreen display" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                 <TextBlock x:Name="CurrentDisplayText" Foreground="#888" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                                <ComboBox x:Name="PreferredDisplayCombo"
                                                          Style="{StaticResource DarkComboBox}"
                                                          HorizontalAlignment="Left" MinWidth="280" Margin="0,0,0,20"/>

                                                <Button Content="Apply" Click="OnApplySettings"
                                                        Background="#E94560" Foreground="White" BorderThickness="0"
                                                        Padding="14,8" HorizontalAlignment="Left" Cursor="Hand"/>
                                            </StackPanel>

                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </TabItem>

                        </TabControl>

        <!-- ── Video Panel (hidden until toggled) ── -->
        <Grid x:Name="VideoPanel" Grid.Row="0" Grid.RowSpan="2" Visibility="Collapsed" Background="Black"
              MouseMove="OnVideoMouseMove" ClipToBounds="True">
            <vlc:VideoView x:Name="VideoPlayer"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"/>

            <Border x:Name="VideoBrightnessOverlay"
                    Background="White"
                    Opacity="0"
                    IsHitTestVisible="False"
                    Panel.ZIndex="1"/>

            <!-- Idle overlay -->
            <Grid x:Name="IdleOverlay"
                  Background="Black"
                  Visibility="Visible"
                  Panel.ZIndex="2">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="🎬" FontSize="72" HorizontalAlignment="Center"/>
                    <TextBlock Text="RemotePlay" FontSize="32" Foreground="#E94560"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock x:Name="IdleIpText" FontSize="16" Foreground="#AAAAAA"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    <Border Background="White" Padding="8" CornerRadius="6" HorizontalAlignment="Center" Margin="0,16,0,0">
                        <Image x:Name="FullscreenQrImage" Width="180" Height="180" Stretch="Uniform"/>
                    </Border>
                    <TextBlock Text="Scan to open RemotePlay" FontSize="13" Foreground="#AAAAAA"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Fullscreen overlay toolbar (auto-hide) — debug access only -->
            <Border x:Name="VideoOverlayToolbar"
                    VerticalAlignment="Top" HorizontalAlignment="Stretch"
                    Background="#CC1a1a2e" Padding="8,6" Opacity="0"
                    Visibility="Collapsed" IsHitTestVisible="False"
                    Panel.ZIndex="10">
                <DockPanel>
                    <TextBlock Text="&#127916; RemotePlay" Foreground="#E94560" FontSize="16"
                               FontWeight="Bold" VerticalAlignment="Center" Margin="4,0,16,0"/>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button Content="&#9003;  Debug" Click="OnToggleView"
                                Background="#333" Foreground="White" BorderThickness="0"
                                Padding="10,4" Margin="4,0" Cursor="Hand"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Transparent hit target that reveals the overlay when the pointer touches the top edge. -->
            <Border x:Name="VideoTopHotZone"
                    VerticalAlignment="Top" HorizontalAlignment="Stretch"
                    Height="18" Background="Transparent"
                    MouseEnter="OnVideoTopHotZoneMouseEnter"
                    Panel.ZIndex="11"/>

            <!-- Now-playing banner -->
            <Border x:Name="NowPlayingBanner"
                    VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                    Background="#AA000000" Padding="24,12" Opacity="0"
                    Panel.ZIndex="9">
                <TextBlock x:Name="NowPlayingText" FontSize="22" Foreground="White"
                           TextTrimming="CharacterEllipsis"/>
            </Border>
        </Grid>

    </Grid>
</Window>

