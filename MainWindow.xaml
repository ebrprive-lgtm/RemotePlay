<Window x:Class="RemotePlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:ctrl="clr-namespace:RemotePlay.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="RemotePlay"
        Icon="pack://application:,,,/Assets/RemotePlay.ico"
        Background="#111111"
        WindowStyle="SingleBorderWindow"
        WindowState="Normal"
        Width="900" Height="620"
        ResizeMode="CanResize"
        PreviewKeyDown="OnWindowPreviewKeyDown"
        PreviewKeyUp="OnWindowPreviewKeyUp"
        SizeChanged="OnWindowSizeChanged"
        StateChanged="OnWindowStateChanged">

    <Window.Resources>
        <!-- Tab header style -->

        <!-- ── Browser context menu styles ─────────────────────────────── -->
        <Style x:Key="BrowserContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="#13131f"/>
            <Setter Property="BorderBrush" Value="#2e2e4e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0,4"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="4" Opacity="0.55" Direction="270"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="5" Opacity="0.6" Direction="270"/>
                            </Border.Effect>
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BrowserMenuItem" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCDD"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7,20,7"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Margin="4,1">
                            <Border x:Name="Accent"
                                    BorderBrush="Transparent"
                                    BorderThickness="2,0,0,0"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter ContentSource="Header"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bg"    Property="Background"    Value="#1e1e38"/>
                                <Setter TargetName="Accent" Property="BorderBrush"  Value="#E94560"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#444460"/>
                                <Setter Property="Cursor"     Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BrowserMenuItemDestructive" TargetType="MenuItem" BasedOn="{StaticResource BrowserMenuItem}">
            <Setter Property="Foreground" Value="#E94560"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Margin="4,1">
                            <Border x:Name="Accent"
                                    BorderBrush="Transparent"
                                    BorderThickness="2,0,0,0"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter ContentSource="Header"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bg"     Property="Background"   Value="#2a0d14"/>
                                <Setter TargetName="Accent" Property="BorderBrush"  Value="#E94560"/>
                                <Setter Property="Foreground" Value="#FF6B80"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#5a2030"/>
                                <Setter Property="Cursor"     Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BrowserMenuSeparator" TargetType="Separator">
            <Setter Property="Background" Value="#2a2a42"/>
            <Setter Property="Margin" Value="12,4"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1" Background="{TemplateBinding Background}" Margin="{TemplateBinding Margin}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BrowserMenuGroupLabel" TargetType="MenuItem">
            <Setter Property="Foreground" Value="#4a4a6a"/>
            <Setter Property="FontSize" Value="9.5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="16,6,16,2"/>
            <Setter Property="IsEnabled" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <TextBlock Text="{TemplateBinding Header}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   Padding="{TemplateBinding Padding}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- ── End browser context menu styles ─────────────────────────── -->

        <Style x:Key="DarkTab" TargetType="TabItem">
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Tab" Background="#1a1a2e" Padding="16,8" Margin="0,0,2,0">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Tab" Property="Background" Value="#0d0d1a"/>
                                <Setter Property="Foreground" Value="#E94560"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Tab" Property="Background" Value="#252540"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Settings category sidebar button style -->
        <Style x:Key="SettingsCatBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1a2035"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBox style -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="Foreground" Value="#EEE"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#1e1e2e"/>
                        <Setter Property="Foreground" Value="#EEE"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#2d2d4e"/>
                                <Setter Property="Foreground" Value="#E94560"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Foreground="{TemplateBinding Foreground}"
                                          Padding="{TemplateBinding Padding}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" Margin="{TemplateBinding Padding}"
                                                                  VerticalAlignment="Center"/>
                                                <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="#888" VerticalAlignment="Center"
                                                      HorizontalAlignment="Center" Margin="0,0,4,0"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,6,24,6"
                                              VerticalAlignment="Center"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <Border Background="#1e1e2e" BorderBrush="#444" BorderThickness="1"
                                            CornerRadius="0,0,3,3">
                                        <ScrollViewer>
                                            <StackPanel IsItemsHost="True"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Startup pulse animation -->
        <Storyboard x:Key="PulseAnim" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0.3" Duration="0:0:0.8"/>
        </Storyboard>

        <!-- Log level filter button style -->
        <Style x:Key="LogFilterBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#778899"/>
            <Setter Property="BorderBrush" Value="#2a2a4a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1a1a38"/>
                                <Setter Property="Foreground" Value="#CCCCEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Tag" Value="Error">
                    <Setter Property="BorderBrush" Value="#552233"/>
                </Trigger>
                <Trigger Property="Tag" Value="Warn">
                    <Setter Property="BorderBrush" Value="#554422"/>
                </Trigger>
                <Trigger Property="Tag" Value="Info">
                    <Setter Property="BorderBrush" Value="#224455"/>
                </Trigger>
                <Trigger Property="Tag" Value="Detail">
                    <Setter Property="BorderBrush" Value="#333355"/>
                </Trigger>
                <Trigger Property="Tag" Value="All">
                    <Setter Property="BorderBrush" Value="#2a2a4a"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#111111">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- toolbar -->
            <RowDefinition Height="*"/>     <!-- content -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar ── -->
        <Border x:Name="AppToolbar" Grid.Row="0" Background="#1a1a2e" Padding="8,6">
            <DockPanel>
                <TextBlock Text="🎬 RemotePlay" Foreground="#E94560" FontSize="16"
                           FontWeight="Bold" VerticalAlignment="Center" Margin="4,0,16,0"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button x:Name="ToggleViewBtn" Content="▶  Switch to Video"
                            Click="OnToggleView"
                            Background="#E94560" Foreground="White" BorderThickness="0"
                            Padding="10,4" Margin="4,0" Cursor="Hand"/>

                    <Button Content="⏹  Stop" Click="OnStopServer"
                            Background="#7a1a1a" Foreground="White" BorderThickness="0"
                            Padding="10,4" Margin="4,0" Cursor="Hand"/>
                    <Button x:Name="RestartServerBtn" Content="↻  Restart" Click="OnRestartServer"
                            Background="#333" Foreground="White" BorderThickness="0"
                            Padding="10,4" Margin="4,0" Cursor="Hand"/>
                    <TextBlock x:Name="ServerStatusText" Foreground="#AAAAAA" FontSize="12"
                               VerticalAlignment="Center" Margin="12,0,4,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Floating corner widget — QR when idle, preview when playing ── -->
        <Border x:Name="CornerWidget" Grid.Row="0" Grid.RowSpan="2"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Panel.ZIndex="20"
                Background="#0d0d1a"
                BorderBrush="#2a2a4a" BorderThickness="0,0,0,1"
                CornerRadius="0,0,0,6"
                Padding="6,6,6,8">
            <Grid>
                <!-- Startup indicator — overlays the corner widget while server is initialising -->
                <Border x:Name="StartupOverlay"
                        Background="#EE0d0d1a"
                        CornerRadius="3"
                        IsHitTestVisible="False"
                        Visibility="Visible">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Margin="6">
                        <Border x:Name="StartupPulseDot"
                                Width="10" Height="10" CornerRadius="5"
                                Background="#FFAA00"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,8"/>
                        <TextBlock x:Name="StartupOverlayText"
                                   Text="Server&#10;starting…"
                                   Foreground="#FFAA00" FontSize="18"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Preview panel — visible while a video is playing -->
                <Border x:Name="MiniPreviewBorder"
                        Visibility="Collapsed"
                        Background="Black"
                        CornerRadius="3"
                        Cursor="Hand"
                        MouseLeftButtonUp="OnMiniPreviewClick"
                        ToolTip="Click to switch to video">
                    <Grid>
                        <Image x:Name="MiniPreviewImage"
                               Width="480" Height="220"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <Border Background="#99000000" VerticalAlignment="Bottom"
                                Padding="4,2" CornerRadius="0,0,3,3">
                            <TextBlock Text="&#9654; Now Playing" Foreground="#E94560"
                                       FontSize="11" HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ── Tab control (debug mode) ── -->
        <TabControl x:Name="MainTabs" Grid.Row="1"
                    Background="#111111" BorderThickness="0"
                    TabStripPlacement="Top"
                    SelectionChanged="OnMainTabsSelectionChanged">

            <!-- ── STATUS / LOG tab ── -->
            <TabItem Header="📋  Status" Style="{StaticResource DarkTab}">
                <Grid Background="#111111">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Info bar -->
                    <Border Grid.Row="0" Background="#0d0d1a" Padding="10,8,105,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Top">
                                <TextBlock x:Name="IpAddressText" Foreground="#00D4AA" FontSize="15"
                                           FontWeight="Bold" TextWrapping="Wrap"/>
                                <!-- Stat pills -->
                                <WrapPanel Margin="0,6,0,0" Orientation="Horizontal">
                                    <Border Background="#121226" BorderBrush="#2a2a4a" BorderThickness="1"
                                            CornerRadius="9" Padding="7,3" Margin="0,2,6,2">
                                        <TextBlock x:Name="LibraryStatText" Foreground="#aaa" FontSize="11" Text="📁 — videos"/>
                                    </Border>
                                    <Border Background="#121226" BorderBrush="#2a2a4a" BorderThickness="1"
                                            CornerRadius="9" Padding="7,3" Margin="0,2,6,2">
                                        <TextBlock x:Name="PeersStatText" Foreground="#aaa" FontSize="11" Text="🌐 — instances"/>
                                    </Border>
                                    <Border Background="#121226" BorderBrush="#2a2a4a" BorderThickness="1"
                                            CornerRadius="9" Padding="7,3" Margin="0,2,0,2">
                                        <TextBlock x:Name="MoviesPathText" Foreground="#666" FontSize="11"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="320"/>
                                    </Border>
                                    <Button x:Name="RescanLibraryBtn"
                                            Content="🔄 Rescan Library"
                                             Click="OnRescanLibrary"
                                            Background="#333"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Padding="10,4"
                                            Margin="8,2,0,2"
                                            Cursor="Hand"/>
                                </WrapPanel>
                                <!-- Startup readiness checklist -->
                                <Border x:Name="StartupChecklistBorder"
                                        Background="#121226"
                                        BorderBrush="#2a2a4a"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8,6"
                                        Margin="0,8,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Startup checklist"
                                                   Foreground="#888"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,4"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                            <Border x:Name="ServerReadyDot" Width="7" Height="7" CornerRadius="3.5"
                                                    Background="#FFAA00"
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"/>
                                            <TextBlock x:Name="ServerReadyText"
                                                       Foreground="#CCC"
                                                       FontSize="11"
                                                       Text="Server: starting…"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Border x:Name="LibraryReadyDot" Width="7" Height="7" CornerRadius="3.5"
                                                    Background="#FFAA00"
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"/>
                                            <TextBlock x:Name="LibraryReadyText"
                                                       Foreground="#CCC"
                                                       FontSize="11"
                                                       Text="Video library: waiting for scan…"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <Border x:Name="MusicIndexReadyDot" Width="7" Height="7" CornerRadius="3.5"
                                                    Background="#FFAA00"
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"/>
                                            <TextBlock x:Name="MusicIndexReadyText"
                                                       Foreground="#CCC"
                                                       FontSize="11"
                                                       Text="Music library: waiting for index…"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <Border x:Name="UpdateReadyDot" Width="7" Height="7" CornerRadius="3.5"
                                                    Background="#555555"
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"/>
                                            <TextBlock x:Name="UpdateReadyText"
                                                       Foreground="#CCC"
                                                       FontSize="11"
                                                       Text="Auto-update: not configured"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <!-- Diagnostic warning (shown only when needed) -->
                                <TextBlock x:Name="DiagText" Foreground="#FFAA00" FontSize="11"
                                           Margin="0,5,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
                                <!-- AlternateUrlText: kept collapsed for code compatibility -->
                                <TextBlock x:Name="AlternateUrlText" Foreground="#888" FontSize="11"
                                           Margin="0,0,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
                            </StackPanel>

                                </Grid>
                            </Border>

                    <!-- Log filter bar + rich log output -->
                    <Grid Grid.Row="1" Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Filter button bar -->
                        <Border Grid.Row="0" Background="#0d0d1a"
                                BorderBrush="#2a2a4a" BorderThickness="1,1,1,0"
                                CornerRadius="4,4,0,0" Padding="6,4">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Level:" Foreground="#666688" FontSize="11"
                                           VerticalAlignment="Center" Margin="2,0,8,0"/>
                                <Button x:Name="LogFilterError"  Content="Error"  Tag="Error"
                                        Click="OnLogFilterClick"
                                        Style="{StaticResource LogFilterBtn}"/>
                                <Button x:Name="LogFilterWarn"   Content="Warn"   Tag="Warn"
                                        Click="OnLogFilterClick"
                                        Style="{StaticResource LogFilterBtn}"/>
                                <Button x:Name="LogFilterDetail" Content="Detail" Tag="Detail"
                                        Click="OnLogFilterClick"
                                        Style="{StaticResource LogFilterBtn}"/>
                                <Button x:Name="LogFilterInfo"   Content="Info"   Tag="Info"
                                        Click="OnLogFilterClick"
                                        Style="{StaticResource LogFilterBtn}"/>
                                <Button x:Name="LogFilterAll"    Content="All"    Tag="All"
                                        Click="OnLogFilterClick"
                                        Style="{StaticResource LogFilterBtn}"/>
                                <TextBlock Text="|" Foreground="#333355" Margin="6,0" VerticalAlignment="Center"/>
                                <Button Content="Clear" Click="OnClearLog"
                                        Background="Transparent" Foreground="#664455"
                                        BorderThickness="0" Padding="6,2" Cursor="Hand"
                                        FontSize="11"/>
                            </StackPanel>
                        </Border>

                        <!-- Rich log output -->
                        <Border Grid.Row="1" Background="#0a0a0a"
                                BorderBrush="#333" BorderThickness="1"
                                CornerRadius="0,0,4,4">
                            <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                                <RichTextBox x:Name="LogRichBox"
                                             Background="Transparent"
                                             FontFamily="Consolas" FontSize="12"
                                             IsReadOnly="True"
                                             BorderThickness="0" Padding="8,6"
                                             IsDocumentEnabled="True"
                                             VerticalAlignment="Top">
                                    <FlowDocument
                                                  PageWidth="4000"
                                                  FontFamily="Consolas"
                                                  FontSize="12"
                                                  LineHeight="17"/>
                                </RichTextBox>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ── SETTINGS tab ── -->
            <TabItem Header="⚙️  Settings" Style="{StaticResource DarkTab}">
                <Grid Background="#111111">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left sidebar -->
                    <Border Grid.Column="0" Background="#0d0d1a" BorderBrush="#2a2a3e" BorderThickness="0,0,1,0">
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="SETTINGS" Foreground="#555" FontSize="10" FontWeight="Bold"
                                       Margin="16,0,0,10"/>
                            <Button x:Name="SettingsCatLibrary"   Content="📁  Library"         Click="OnSettingsCat" Tag="Library"   Style="{StaticResource SettingsCatBtn}" Background="#1a2a3a" Foreground="#E94560"/>
                            <Button x:Name="SettingsCatServer"    Content="🌐  Server"          Click="OnSettingsCat" Tag="Server"    Style="{StaticResource SettingsCatBtn}"/>
                            <Button x:Name="SettingsCatPlayback"  Content="▶  Playback"         Click="OnSettingsCat" Tag="Playback"  Style="{StaticResource SettingsCatBtn}"/>
                            <Button x:Name="SettingsCatTracks"    Content="🎵  Audio &amp; Subs"   Click="OnSettingsCat" Tag="Tracks"    Style="{StaticResource SettingsCatBtn}"/>
                            <Button x:Name="SettingsCatDisplay"   Content="🖥  Display"          Click="OnSettingsCat" Tag="Display"   Style="{StaticResource SettingsCatBtn}"/>
                            <Button x:Name="SettingsCatStartup"   Content="🚀  Startup"          Click="OnSettingsCat" Tag="Startup"   Style="{StaticResource SettingsCatBtn}"/>
                            <Button x:Name="SettingsCatAdvanced"  Content="🔧  Advanced"         Click="OnSettingsCat" Tag="Advanced"  Style="{StaticResource SettingsCatBtn}"/>
                        </StackPanel>
                    </Border>

                    <!-- Right content area -->
                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Background="#111111">
                        <StackPanel Margin="28,24,28,24">

                            <!-- Feedback banner (shared) -->
                            <TextBlock x:Name="SettingsFeedback" Foreground="#00D4AA"
                                       FontSize="12" Margin="0,0,0,16"
                                       Visibility="Collapsed" TextWrapping="Wrap"/>

                            <!-- ── LIBRARY panel ── -->
                            <StackPanel x:Name="PanelLibrary" Visibility="Visible">
                                <TextBlock Text="Library" Foreground="#E94560" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Foreground="#666" FontSize="11" Margin="0,0,0,20"
                                           Text="The folder scanned for video files (.mp4 .mkv .avi .mov .wmv .m4v .ts .flv). All subfolders are included."/>

                                <TextBlock Text="Movies Folder" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="MoviesFolderBox" Grid.Column="0"
                                             Background="#1e1e2e" Foreground="#EEE"
                                             BorderBrush="#444" BorderThickness="1"
                                             Padding="8,6" FontSize="13"
                                              VerticalContentAlignment="Center"
                                              LostFocus="OnSettingLostFocus"/>
                                    <Button Grid.Column="1" Content="Browse…" Click="OnBrowseFolder"
                                            Background="#333" Foreground="White" BorderThickness="0"
                                            Padding="12,6" Margin="8,0,0,0" Cursor="Hand"/>
                                </Grid>

                                <TextBlock Text="Additional Movies Folders" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Foreground="#555" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"
                                           Text="Extra roots scanned alongside the primary Movies folder. All sub-folders are included."/>
                                <ctrl:PathListEditor x:Name="AdditionalMoviesPathsEditor"
                                                     BrowseTitle="Select an additional movies folder"
                                                      PathsChanged="OnPathListSettingChanged"
                                                     Margin="0,0,0,20"/>

                                <TextBlock Text="Music Folder" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="MusicFolderBox" Grid.Column="0"
                                             Background="#1e1e2e" Foreground="#EEE"
                                             BorderBrush="#444" BorderThickness="1"
                                             Padding="8,6" FontSize="13"
                                              VerticalContentAlignment="Center"
                                              LostFocus="OnSettingLostFocus"/>
                                    <Button Grid.Column="1" Content="Browse…" Click="OnBrowseMusicFolder"
                                            Background="#333" Foreground="White" BorderThickness="0"
                                            Padding="12,6" Margin="8,0,0,0" Cursor="Hand"/>
                                </Grid>
                                <TextBlock Foreground="#555" FontSize="11" Margin="0,0,0,20" TextWrapping="Wrap"
                                           Text="Root folder scanned for music files (.mp3 .flac .aac .ogg .wav .m4a .wma .opus). All subfolders are included."/>

                                <TextBlock Text="Additional Music Folders" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Foreground="#555" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"
                                           Text="Extra roots scanned alongside the primary Music folder."/>
                                <ctrl:PathListEditor x:Name="AdditionalMusicPathsEditor"
                                                     BrowseTitle="Select an additional music folder"
                                                      PathsChanged="OnPathListSettingChanged"
                                                     Margin="0,0,0,20"/>

                                <TextBlock Text="Network Share Credentials" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Foreground="#555" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"
                                           Text="Credentials for UNC shares (e.g. \\server\share) that require authentication. The app uses these to connect before scanning. Passwords are stored in plain text — keep the config file private."/>
                                <ctrl:NetworkCredentialsEditor x:Name="CredentialsEditor"
                                                               CredentialsChanged="OnPathListSettingChanged"
                                                               Margin="0,0,0,20"/>

                                <TextBlock Text="Delayed auto-rescan interval" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="AutoRescanIntervalMinutesBox" Grid.Column="0"
                                                 Background="#1e1e2e" Foreground="#EEE"
                                                 BorderBrush="#444" BorderThickness="1"
                                                 Padding="8,6" FontSize="13"
                                                  VerticalContentAlignment="Center"
                                                  LostFocus="OnSettingLostFocus"/>
                                        <TextBlock Grid.Column="1" Foreground="#555" FontSize="11"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                                   Text="Minutes between delayed library auto-rescans (0 disables auto-rescan)."/>
                                    </Grid>

                                    <TextBlock Text="Auto-Update Source Folder" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="UpdateSourcePathBox" Grid.Column="0"
                                                 Background="#1e1e2e" Foreground="#EEE"
                                                 BorderBrush="#444" BorderThickness="1"
                                                 Padding="8,6" FontSize="13"
                                                  VerticalContentAlignment="Center"
                                                  LostFocus="OnSettingLostFocus"/>
                                        <Button Grid.Column="1" Content="Browse…" Click="OnBrowseUpdateSourceFolder"
                                                Background="#333" Foreground="White" BorderThickness="0"
                                                Padding="12,6" Margin="8,0,0,0" Cursor="Hand"/>
                                    </Grid>
                                    <TextBlock Foreground="#555" FontSize="11" Margin="0,0,0,20" TextWrapping="Wrap"
                                               Text="Folder containing updated app files. Leave empty to disable auto-update. Checked at startup and periodically."/>

                                    <TextBlock Text="Auto-Update Check Interval" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="AutoUpdateIntervalMinutesBox" Grid.Column="0"
                                                 Background="#1e1e2e" Foreground="#EEE"
                                                 BorderBrush="#444" BorderThickness="1"
                                                 Padding="8,6" FontSize="13"
                                                  VerticalContentAlignment="Center"
                                                  LostFocus="OnSettingLostFocus"/>
                                        <TextBlock Grid.Column="1" Foreground="#555" FontSize="11"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                                   Text="Minutes between update checks while the app is running (0 = startup only)."/>
                                    </Grid>

                                    <Button Content="Apply &amp; Restart Server" Click="OnApplySettings"
                                        Background="#E94560" Foreground="White" BorderThickness="0"
                                        Padding="14,8" HorizontalAlignment="Left" Cursor="Hand"/>

                                <!-- ── Advanced library settings ── -->
                                <TextBlock Text="Advanced" Foreground="#E94560" FontSize="13" FontWeight="Bold" Margin="0,28,0,14"/>

                                <CheckBox x:Name="EnableThumbnailGenerationBox"
                                          Content="Generate thumbnails for video files"
                                           Foreground="#EEE" FontSize="13" Margin="0,0,0,6"
                                           Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>
                                <TextBlock Foreground="#555" FontSize="11" Margin="0,0,0,20" TextWrapping="Wrap"
                                           Text="When enabled, RemotePlay generates preview thumbnails for library videos in the background. Disable if disk space or CPU is a concern."/>

                                <TextBlock Text="Library page size" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="LibraryPageSizeBox" Grid.Column="0"
                                             Background="#1e1e2e" Foreground="#EEE"
                                             BorderBrush="#444" BorderThickness="1"
                                             Padding="8,6" FontSize="13"
                                              VerticalContentAlignment="Center"
                                              LostFocus="OnSettingLostFocus"/>
                                    <TextBlock Grid.Column="1" Foreground="#555" FontSize="11"
                                               VerticalAlignment="Center" Margin="12,0,0,0"
                                               Text="Videos per page in the browser (25 – 1000)."/>
                                </Grid>

                                <TextBlock Text="Ignored sub-folders" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,14,0,6"/>
                                <TextBox x:Name="IgnoredLibraryFoldersBox"
                                         Background="#1e1e2e" Foreground="#EEE"
                                         BorderBrush="#444" BorderThickness="1"
                                         Padding="8,6" FontSize="13"
                                         VerticalContentAlignment="Center"
                                          Margin="0,0,0,6"
                                          LostFocus="OnSettingLostFocus"/>
                                <TextBlock Foreground="#555" FontSize="11" Margin="0,0,0,20" TextWrapping="Wrap"
                                           Text="Comma-separated folder names to skip during library scans (e.g. Subs, Alt, Extras). Sub-folders matching any name are excluded entirely."/>

                                <TextBlock Text="Video file extensions" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox x:Name="VideoFileExtensionsBox"
                                         Background="#1e1e2e" Foreground="#EEE"
                                         BorderBrush="#444" BorderThickness="1"
                                         Padding="8,6" FontSize="13"
                                         VerticalContentAlignment="Center"
                                          Margin="0,0,0,6"
                                          LostFocus="OnSettingLostFocus"/>
                                <TextBlock Foreground="#555" FontSize="11" Margin="0,0,0,20" TextWrapping="Wrap"
                                           Text="Comma-separated list of extensions recognised as video files (e.g. .mp4, .mkv, .avi). Leave empty to restore defaults."/>

                                <TextBlock Text="Music file extensions" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox x:Name="MusicFileExtensionsBox"
                                         Background="#1e1e2e" Foreground="#EEE"
                                         BorderBrush="#444" BorderThickness="1"
                                         Padding="8,6" FontSize="13"
                                         VerticalContentAlignment="Center"
                                          Margin="0,0,0,6"
                                          LostFocus="OnSettingLostFocus"/>
                                <TextBlock Foreground="#555" FontSize="11" Margin="0,0,0,20" TextWrapping="Wrap"
                                           Text="Comma-separated list of extensions recognised as music files (e.g. .mp3, .flac, .ogg). Leave empty to restore defaults."/>

                            </StackPanel>

                            <!-- ── SERVER panel ── -->
                            <StackPanel x:Name="PanelServer" Visibility="Collapsed">
                                <TextBlock Text="Server" Foreground="#E94560" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Foreground="#666" FontSize="11" Margin="0,0,0,20"
                                           Text="Configure the web interface port and HTTPS settings."/>

                                <TextBlock Text="Instance Name" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox x:Name="InstanceNameBox"
                                         Background="#1e1e2e" Foreground="#EEE"
                                         BorderBrush="#444" BorderThickness="1"
                                         Padding="8,6" FontSize="13"
                                         VerticalContentAlignment="Center"
                                          Margin="0,0,0,4"
                                          LostFocus="OnSettingLostFocus"/>
                                <TextBlock Foreground="#555" FontSize="11" Margin="0,0,0,20" TextWrapping="Wrap"
                                           Text="Friendly label shown when other RemotePlay instances discover this one on the network (e.g. Living Room, Bedroom PC)."/>

                                <TextBlock Text="Port" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PortBox" Grid.Column="0"
                                             Background="#1e1e2e" Foreground="#EEE"
                                             BorderBrush="#444" BorderThickness="1"
                                             Padding="8,6" FontSize="13"
                                              VerticalContentAlignment="Center"
                                              LostFocus="OnSettingLostFocus"/>
                                    <TextBlock Grid.Column="1" Foreground="#555" FontSize="11"
                                               VerticalAlignment="Center" Margin="12,0,0,0"
                                               Text="(1024 – 65535)"/>
                                </Grid>

                                <CheckBox x:Name="UseHttpsBox"
                                          Content="Use secure HTTPS (recommended for mobile PWA)"
                                           Foreground="#EEE" FontSize="13" Margin="0,12,0,6"
                                           Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>
                                <TextBlock Foreground="#555" FontSize="11" Margin="0,0,0,20" TextWrapping="Wrap"
                                           Text="HTTPS lets mobile browsers install RemotePlay as a PWA. First-time setup may require running as administrator. Browsers may prompt you to trust the local certificate."/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <Button Content="Export HTTPS Certificate" Click="OnExportCertificate"
                                            Background="#333" Foreground="White" BorderThickness="0"
                                            Padding="12,6" Cursor="Hand"/>
                                    <Button Content="Open Health Page" Click="OnOpenHealthPage"
                                            Background="#333" Foreground="White" BorderThickness="0"
                                            Padding="12,6" Margin="8,0,0,0" Cursor="Hand"/>
                                </StackPanel>

                                <!-- ── Rate limiting ── -->
                                <TextBlock Text="Rate Limiting" Foreground="#E94560" FontSize="13" FontWeight="Bold" Margin="0,8,0,14"/>

                                <TextBlock Text="Max requests per IP per window" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="MaxRequestsPerIpBox" Grid.Column="0"
                                             Background="#1e1e2e" Foreground="#EEE"
                                             BorderBrush="#444" BorderThickness="1"
                                             Padding="8,6" FontSize="13"
                                              VerticalContentAlignment="Center"
                                              LostFocus="OnSettingLostFocus"/>
                                    <TextBlock Grid.Column="1" Foreground="#555" FontSize="11"
                                               VerticalAlignment="Center" Margin="12,0,0,0"
                                               Text="Maximum HTTP requests accepted from one IP in the window below. Set to 0 to disable rate limiting."/>
                                </Grid>

                                <TextBlock Text="Rate limit window (seconds)" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,12,0,6"/>
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="RateLimitWindowSecondsBox" Grid.Column="0"
                                             Background="#1e1e2e" Foreground="#EEE"
                                             BorderBrush="#444" BorderThickness="1"
                                             Padding="8,6" FontSize="13"
                                              VerticalContentAlignment="Center"
                                              LostFocus="OnSettingLostFocus"/>
                                    <TextBlock Grid.Column="1" Foreground="#555" FontSize="11"
                                               VerticalAlignment="Center" Margin="12,0,0,0"
                                               Text="Sliding window duration in seconds used to count requests per IP."/>
                                </Grid>

                                <Button Content="Apply &amp; Restart Server" Click="OnApplySettings"
                                        Background="#E94560" Foreground="White" BorderThickness="0"
                                        Padding="14,8" HorizontalAlignment="Left" Cursor="Hand"/>
                            </StackPanel>

                            <!-- ── PLAYBACK panel ── -->
                            <StackPanel x:Name="PanelPlayback" Visibility="Collapsed">
                                <TextBlock Text="Playback" Foreground="#E94560" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Foreground="#666" FontSize="11" Margin="0,0,0,20"
                                           Text="Default behaviour when a video finishes playing."/>

                                <TextBlock Text="When a video ends" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <ComboBox x:Name="PlaybackEndBehaviorCombo"
                                          Style="{StaticResource DarkComboBox}"
                                           HorizontalAlignment="Left" MinWidth="220" Margin="0,0,0,20"
                                           SelectionChanged="OnSettingChanged">
                                    <ComboBoxItem Content="Stop playback" Tag="Stop"/>
                                    <ComboBoxItem Content="Play next video automatically" Tag="PlayNext"/>
                                    <ComboBoxItem Content="Return to library" Tag="ReturnToLibrary"/>
                                </ComboBox>

                                <TextBlock Text="Playback history limit" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PlaybackHistoryLimitBox" Grid.Column="0"
                                             Background="#1e1e2e" Foreground="#EEE"
                                             BorderBrush="#444" BorderThickness="1"
                                             Padding="8,6" FontSize="13"
                                              VerticalContentAlignment="Center"
                                              LostFocus="OnSettingLostFocus"/>
                                    <TextBlock Grid.Column="1" Foreground="#555" FontSize="11"
                                               VerticalAlignment="Center" Margin="12,0,0,0"
                                               Text="Maximum number of movies kept in Continue Watching / recent history."/>
                                </Grid>

                                <Button Content="Apply &amp; Restart Server" Click="OnApplySettings"
                                        Background="#E94560" Foreground="White" BorderThickness="0"
                                        Padding="14,8" HorizontalAlignment="Left" Cursor="Hand"/>
                            </StackPanel>

                            <!-- ── AUDIO & SUBS panel ── -->
                            <StackPanel x:Name="PanelTracks" Visibility="Collapsed">
                                <TextBlock Text="Audio &amp; Subtitles" Foreground="#E94560" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Foreground="#666" FontSize="11" Margin="0,0,0,20" TextWrapping="Wrap"
                                           Text="Language preferences applied automatically when a video starts."/>

                                <TextBlock Text="Audio" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,22">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="240"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Preferred language" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="PreferredAudioLangCombo" Grid.Column="1"
                                               Style="{StaticResource DarkComboBox}"
                                               SelectionChanged="OnSettingChanged"/>
                                    <TextBlock Grid.Column="2" Foreground="#555" FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"
                                               Text="Blank uses the default audio track."/>
                                </Grid>

                                <TextBlock Text="Subtitles" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="240"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Primary language" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="PreferredSubtitleLangCombo" Grid.Column="1"
                                               Style="{StaticResource DarkComboBox}"
                                               SelectionChanged="OnSettingChanged"/>
                                    <TextBlock Grid.Column="2" Foreground="#555" FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"
                                               Text="Tried first when matching subtitle tracks."/>
                                </Grid>

                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="240"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Secondary language" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="SecondarySubtitleLangCombo" Grid.Column="1"
                                               Style="{StaticResource DarkComboBox}"
                                               SelectionChanged="OnSettingChanged"/>
                                    <TextBlock Grid.Column="2" Foreground="#555" FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"
                                               Text="Optional fallback if the primary subtitle language is unavailable."/>
                                </Grid>

                                <CheckBox x:Name="PreferForcedSubtitlesBox"
                                          Content="Prefer forced subtitle tracks (dialogue subtitles for foreign language portions)"
                                           Foreground="#EEE" FontSize="13" Margin="0,0,0,24"
                                           Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>

                                <TextBlock Text="Music Output" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="280"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Audio output device" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="MusicAudioDeviceCombo" Grid.Column="1"
                                              Style="{StaticResource DarkComboBox}"
                                               DisplayMemberPath="Name"
                                               SelectionChanged="OnSettingChanged"/>
                                    <TextBlock Grid.Column="2" Foreground="#555" FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"
                                               Text="Select the audio device used for music playback on this server machine."/>
                                </Grid>
                                <TextBlock Foreground="#555" FontSize="11" Margin="160,0,0,16" TextWrapping="Wrap"
                                           Text="'(Default)' uses the current Windows default output. Choose a specific device to route music independently (e.g. audio via video cable vs. audio driver)."/>

                                <Button Content="Apply &amp; Restart Server" Click="OnApplySettings"
                                        Background="#E94560" Foreground="White" BorderThickness="0"
                                        Padding="14,8" HorizontalAlignment="Left" Cursor="Hand"/>
                            </StackPanel>

                                            <!-- ── DISPLAY panel ── -->
                                            <StackPanel x:Name="PanelDisplay" Visibility="Collapsed">
                                                <TextBlock Text="Display" Foreground="#E94560" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
                                                <TextBlock Foreground="#666" FontSize="11" Margin="0,0,0,20" TextWrapping="Wrap"
                                                           Text="Choose which monitor the fullscreen video window opens on."/>

                                                <TextBlock Text="Fullscreen display" Foreground="#CCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                 <TextBlock x:Name="CurrentDisplayText" Foreground="#888" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                                <ComboBox x:Name="PreferredDisplayCombo"
                                                          Style="{StaticResource DarkComboBox}"
                                                           HorizontalAlignment="Left" MinWidth="280" Margin="0,0,0,20"
                                                           SelectionChanged="OnSettingChanged"/>

                                                <Button Content="Apply" Click="OnApplySettings"
                                                        Background="#E94560" Foreground="White" BorderThickness="0"
                                                        Padding="14,8" HorizontalAlignment="Left" Cursor="Hand"/>
                                            </StackPanel>

                            <!-- ── STARTUP panel ── -->
                            <StackPanel x:Name="PanelStartup" Visibility="Collapsed">
                                <TextBlock Text="Startup" Foreground="#E94560" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Foreground="#666" FontSize="11" Margin="0,0,0,20" TextWrapping="Wrap"
                                           Text="Choose whether RemotePlay starts with Windows and keeps running in the system tray when closed."/>

                                <CheckBox x:Name="StartWithWindowsBox"
                                          Content="Start RemotePlay when Windows starts"
                                           Foreground="#EEE" FontSize="13" Margin="0,0,0,8"
                                           Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>
                                <TextBlock Foreground="#555" FontSize="11" Margin="0,0,0,18" TextWrapping="Wrap"
                                           Text="Adds or removes RemotePlay from your current user's Windows startup apps."/>

                                <CheckBox x:Name="UseTrayIconBox"
                                          Content="Keep RemotePlay in the system tray when closed"
                                           Foreground="#EEE" FontSize="13" Margin="0,0,0,8"
                                           Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>
                                <TextBlock Foreground="#555" FontSize="11" Margin="0,0,0,20" TextWrapping="Wrap"
                                           Text="When enabled, closing the window hides RemotePlay to the tray instead of exiting. Web playback can restore the app and enter fullscreen."/>

                                <Button Content="Apply" Click="OnApplySettings"
                                        Background="#E94560" Foreground="White" BorderThickness="0"
                                        Padding="14,8" HorizontalAlignment="Left" Cursor="Hand"/>
                            </StackPanel>

                            <!-- ── ADVANCED panel ── -->
                            <StackPanel x:Name="PanelAdvanced" Visibility="Collapsed">
                                <TextBlock Text="Advanced" Foreground="#E94560" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Foreground="#666" FontSize="11" Margin="0,0,0,20" TextWrapping="Wrap"
                                           Text="Expert Mode unlocks additional controls in the web UI, such as creating dynamic folders."/>

                                <CheckBox x:Name="ExpertModeBox"
                                          Content="Expert Mode"
                                          Foreground="#EEE" FontSize="13" Margin="0,0,0,8"
                                          Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>
                                <TextBlock Foreground="#555" FontSize="11" Margin="0,0,0,20" TextWrapping="Wrap"
                                           Text="When enabled, expert-only controls become visible in the web interface (e.g. creating dynamic folders)."/>

                                <CheckBox x:Name="DebugModeBox"
                                          Content="Debug Mode"
                                          Foreground="#EEE" FontSize="13" Margin="0,0,0,8"
                                          Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>
                                <TextBlock Foreground="#555" FontSize="11" Margin="0,0,0,20" TextWrapping="Wrap"
                                           Text="When enabled, debug-only controls become visible in the web interface (e.g. Reset M3U cache)."/>

                                <Button Content="Apply" Click="OnApplySettings"
                                        Background="#E94560" Foreground="White" BorderThickness="0"
                                        Padding="14,8" HorizontalAlignment="Left" Cursor="Hand"/>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ── LIBRARY LINKS tab ── -->
            <TabItem Header="🔗  Links" Style="{StaticResource DarkTab}">
                <Grid Background="#111111">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Top toolbar -->
                    <Border Grid.Row="0" Background="#0d0d1a" Padding="12,8" BorderBrush="#2a2a3e" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <TextBlock Text="LIBRARY LINK BROWSER" Foreground="#555" FontSize="10"
                                       FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="StaleLinkBadge"
                                       Foreground="#E94560" FontSize="11" FontWeight="Bold"
                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                       Visibility="Collapsed"
                                       ToolTip="Broken links detected — use 'Scan broken links' or right-click a link to auto-heal or retarget"/>
                            <Button x:Name="RegisterContextMenuBtn"
                                    Content="📋  Register Explorer context menu"
                                    Click="OnRegisterContextMenu"
                                    Background="#333" Foreground="White"
                                    BorderThickness="0" Padding="10,5" Margin="16,0,0,0"
                                    Cursor="Hand" DockPanel.Dock="Right"
                                    ToolTip="Adds 'Create RemotePlay Link' to the right-click menu for video files in Explorer"/>
                            <Button Content="🔍  Scan broken links"
                                    Click="OnScanBrokenLinks"
                                    Background="#333" Foreground="White"
                                    BorderThickness="0" Padding="10,5" Margin="8,0,0,0"
                                    Cursor="Hand" DockPanel.Dock="Right"
                                    ToolTip="Scan the entire library for .rplink files whose targets no longer exist"/>
                        </DockPanel>
                    </Border>

                    <!-- Dual file browser -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ── LEFT browser: folders + video files ── -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Border Grid.Row="0" Background="#0d0d1a" Padding="10,6" BorderBrush="#2a2a3e" BorderThickness="0,0,0,1" MinHeight="34">
                                <DockPanel>
                                    <Button Content="→"
                                            DockPanel.Dock="Right"
                                            Click="OnSyncLeftToRight"
                                            Background="#1e1e2e" Foreground="#00D4AA"
                                            BorderThickness="0" Padding="8,2"
                                            FontSize="14" FontWeight="Bold"
                                            Cursor="Hand"
                                            ToolTip="Navigate right browser to the same folder as the left browser"/>
                                    <TextBlock Text="📁  LIBRARY" Foreground="#888" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>

                            <!-- Current path breadcrumb -->
                            <Border Grid.Row="1" Background="#0a0a14" Padding="4,2" BorderBrush="#2a2a3e" BorderThickness="0,0,0,1">
                                <ItemsControl x:Name="LeftBreadcrumbs"
                                              VerticalAlignment="Center">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="{Binding Name}"
                                                        Tag="{Binding Dir}"
                                                        Click="OnLeftBreadcrumbClick"
                                                        Background="Transparent" BorderThickness="0"
                                                        Foreground="#00D4AA" FontSize="11"
                                                        Padding="4,2" Cursor="Hand"
                                                        ToolTip="{Binding Dir}"/>
                                                <TextBlock Text=" › " Foreground="#555" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>

                            <!-- File list -->
                            <ListView x:Name="LeftBrowser"
                                      Grid.Row="2"
                                      Background="#0d0d1a" Foreground="#CCC"
                                      BorderThickness="0"
                                      SelectionMode="Extended"
                                      MouseDoubleClick="OnLeftBrowserDoubleClick">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#CCC"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Padding" Value="4,3"/>
                                        <Setter Property="ToolTip" Value="{Binding TargetTooltip}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBroken}" Value="True">
                                                <Setter Property="Foreground" Value="#E94560"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IndexStateLabel}" Value="InIndex">
                                                <Setter Property="Foreground" Value="#00D4AA"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IndexStateLabel}" Value="NotInIndex">
                                                <Setter Property="Foreground" Value="#E94560"/>
                                            </DataTrigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#2d2d4e"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1a1a3e"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn x:Name="LeftColName" Width="220">
                                            <GridViewColumn.Header>
                                                <TextBlock Text="Name" Foreground="#888" FontSize="11"/>
                                            </GridViewColumn.Header>
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock FontSize="12" Margin="0,0,4,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value=""/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsFolderLink}" Value="True">
                                                                            <Setter Property="Text" Value="📁 "/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="12"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn x:Name="LeftColType" Width="60">
                                            <GridViewColumn.Header>
                                                <TextBlock Text="Type" Foreground="#888" FontSize="11"/>
                                            </GridViewColumn.Header>
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding TypeLabel}" Foreground="#666" FontSize="11"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn x:Name="LeftColTarget" Width="260">
                                            <GridViewColumn.Header>
                                                <TextBlock Text="Target" Foreground="#888" FontSize="11"/>
                                            </GridViewColumn.Header>
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding TargetDisplay}" FontSize="11"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding TargetDisplay}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                                <ListView.ContextMenu>
                                    <ContextMenu Opened="OnBrowserContextMenuOpened"
                                                Style="{StaticResource BrowserContextMenu}"
                                                Tag="Left">

                                       <!-- ── File actions (video files only) ── -->
                                       <MenuItem Tag="CreateLinks"
                                                 Style="{StaticResource BrowserMenuItem}"
                                                 Click="OnBrowserCreateLinks"/>
                                       <MenuItem Tag="FindLinks"
                                                 Style="{StaticResource BrowserMenuItem}"
                                                 Click="OnBrowserFindLinks"/>
                                       <MenuItem Tag="RenameFile"
                                                 Style="{StaticResource BrowserMenuItem}"
                                                 Click="OnBrowserRename"/>
                                       <MenuItem Tag="MoveFiles"
                                                 Style="{StaticResource BrowserMenuItem}"
                                                 Click="OnBrowserMoveFiles"/>
                                       <MenuItem Tag="DeleteFiles"
                                                 Style="{StaticResource BrowserMenuItemDestructive}"
                                                 Click="OnBrowserDeleteFiles"/>

                                        <Separator Tag="SepFileFolder" Style="{StaticResource BrowserMenuSeparator}"/>

                                        <!-- ── Link actions (.rplink files only) ── -->
                                        <MenuItem Tag="RenameLink"
                                                  Style="{StaticResource BrowserMenuItem}"
                                                  Click="OnBrowserRename"/>
                                        <MenuItem Tag="MoveLink"
                                                  Style="{StaticResource BrowserMenuItem}"
                                                  Click="OnBrowserMoveLink"/>
                                        <MenuItem Tag="BulkRetarget"
                                                  Style="{StaticResource BrowserMenuItem}"
                                                  Click="OnBrowserBulkRetarget"/>
                                        <MenuItem Tag="AutoHeal"
                                                  Style="{StaticResource BrowserMenuItem}"
                                                  Click="OnBrowserAutoHeal"/>
                                        <MenuItem Tag="DeleteLinks"
                                                  Style="{StaticResource BrowserMenuItemDestructive}"
                                                  Click="OnBrowserDeleteLinks"/>

                                        <Separator Tag="SepLinkFolder" Style="{StaticResource BrowserMenuSeparator}"/>

                                        <!-- ── Folder actions (folders only) ── -->
                                        <MenuItem Tag="CreateFolderLink"
                                                  Style="{StaticResource BrowserMenuItem}"
                                                  Click="OnBrowserCreateFolderLink"/>
                                        <MenuItem Tag="MoveFolder"
                                                  Style="{StaticResource BrowserMenuItem}"
                                                  Click="OnBrowserMoveFolder"/>
                                        <MenuItem Tag="CreateFolder"
                                                  Style="{StaticResource BrowserMenuItem}"
                                                  Click="OnBrowserCreateFolder"/>
                                        <MenuItem Tag="RenameFolder"
                                                  Style="{StaticResource BrowserMenuItem}"
                                                  Click="OnBrowserRename"/>
                                        <MenuItem Tag="DeleteFolder"
                                                  Style="{StaticResource BrowserMenuItemDestructive}"
                                                  Click="OnBrowserDeleteFolder"/>

                                        <Separator Tag="SepCheckIndex" Style="{StaticResource BrowserMenuSeparator}"/>

                                        <!-- ── Index diagnostic (always visible) ── -->
                                        <MenuItem Tag="CheckIndex"
                                                  Style="{StaticResource BrowserMenuItem}"
                                                  Click="OnBrowserCheckIndex"/>

                                    </ContextMenu>
                                </ListView.ContextMenu>
                            </ListView>
                        </Grid>

                        <!-- Splitter -->
                        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                                      Background="#2a2a3e" ResizeBehavior="PreviousAndNext"/>

                        <!-- ── RIGHT browser: folders + rplink files ── -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Border Grid.Row="0" Background="#0d0d1a" Padding="10,6" BorderBrush="#2a2a3e" BorderThickness="0,0,0,1" MinHeight="34">
                                <TextBlock Text="🔗  LIBRARY" Foreground="#888" FontSize="10" FontWeight="Bold"/>
                            </Border>

                            <!-- Current path breadcrumb -->
                            <Border Grid.Row="1" Background="#0a0a14" Padding="4,2" BorderBrush="#2a2a3e" BorderThickness="0,0,0,1">
                                <ItemsControl x:Name="RightBreadcrumbs"
                                              VerticalAlignment="Center">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="{Binding Name}"
                                                        Tag="{Binding Dir}"
                                                        Click="OnRightBreadcrumbClick"
                                                        Background="Transparent" BorderThickness="0"
                                                        Foreground="#00D4AA" FontSize="11"
                                                        Padding="4,2" Cursor="Hand"
                                                        ToolTip="{Binding Dir}"/>
                                                <TextBlock Text=" › " Foreground="#555" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>

                            <!-- File list -->
                            <ListView x:Name="RightBrowser"
                                      Grid.Row="2"
                                      Background="#0d0d1a" Foreground="#CCC"
                                      BorderThickness="0"
                                      SelectionMode="Extended"
                                      MouseDoubleClick="OnRightBrowserDoubleClick">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#CCC"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Padding" Value="4,3"/>
                                        <Setter Property="ToolTip" Value="{Binding TargetTooltip}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBroken}" Value="True">
                                                <Setter Property="Foreground" Value="#E94560"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IndexStateLabel}" Value="InIndex">
                                                <Setter Property="Foreground" Value="#00D4AA"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IndexStateLabel}" Value="NotInIndex">
                                                <Setter Property="Foreground" Value="#E94560"/>
                                            </DataTrigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#2d2d4e"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1a1a3e"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.View>
                                    <GridView>
                                         <GridViewColumn x:Name="RightColName" Width="220">
                                            <GridViewColumn.Header>
                                                <TextBlock Text="Name" Foreground="#888" FontSize="11"/>
                                            </GridViewColumn.Header>
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock FontSize="12" Margin="0,0,4,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value=""/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsFolderLink}" Value="True">
                                                                            <Setter Property="Text" Value="📁 "/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="12"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn x:Name="RightColType" Width="60">
                                            <GridViewColumn.Header>
                                                <TextBlock Text="Type" Foreground="#888" FontSize="11"/>
                                            </GridViewColumn.Header>
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding TypeLabel}" Foreground="#666" FontSize="11"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn x:Name="RightColTarget" Width="260">
                                           <GridViewColumn.Header>
                                               <TextBlock Text="Target" Foreground="#888" FontSize="11"/>
                                           </GridViewColumn.Header>
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding TargetDisplay}" FontSize="11"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding TargetDisplay}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                                <ListView.ContextMenu>
                                    <ContextMenu Opened="OnBrowserContextMenuOpened"
                                                Style="{StaticResource BrowserContextMenu}"
                                                Tag="Right">

                                       <!-- ── File actions (video files only) ── -->
                                       <MenuItem Tag="CreateLinks"
                                                 Style="{StaticResource BrowserMenuItem}"
                                                 Click="OnBrowserCreateLinks"/>
                                       <MenuItem Tag="FindLinks"
                                                 Style="{StaticResource BrowserMenuItem}"
                                                 Click="OnBrowserFindLinks"/>
                                       <MenuItem Tag="RenameFile"
                                                 Style="{StaticResource BrowserMenuItem}"
                                                 Click="OnBrowserRename"/>
                                       <MenuItem Tag="MoveFiles"
                                                 Style="{StaticResource BrowserMenuItem}"
                                                 Click="OnBrowserMoveFiles"/>
                                       <MenuItem Tag="DeleteFiles"
                                                 Style="{StaticResource BrowserMenuItemDestructive}"
                                                 Click="OnBrowserDeleteFiles"/>

                                        <Separator Tag="SepFileFolder" Style="{StaticResource BrowserMenuSeparator}"/>

                                        <!-- ── Link actions (.rplink files only) ── -->
                                        <MenuItem Tag="RenameLink"
                                                  Style="{StaticResource BrowserMenuItem}"
                                                  Click="OnBrowserRename"/>
                                        <MenuItem Tag="MoveLink"
                                                  Style="{StaticResource BrowserMenuItem}"
                                                  Click="OnBrowserMoveLink"/>
                                        <MenuItem Tag="BulkRetarget"
                                                  Style="{StaticResource BrowserMenuItem}"
                                                  Click="OnBrowserBulkRetarget"/>
                                        <MenuItem Tag="AutoHeal"
                                                  Style="{StaticResource BrowserMenuItem}"
                                                  Click="OnBrowserAutoHeal"/>
                                        <MenuItem Tag="DeleteLinks"
                                                  Style="{StaticResource BrowserMenuItemDestructive}"
                                                  Click="OnBrowserDeleteLinks"/>

                                        <Separator Tag="SepLinkFolder" Style="{StaticResource BrowserMenuSeparator}"/>

                                        <!-- ── Folder actions (folders only) ── -->
                                        <MenuItem Tag="CreateFolderLink"
                                                  Style="{StaticResource BrowserMenuItem}"
                                                  Click="OnBrowserCreateFolderLink"/>
                                        <MenuItem Tag="MoveFolder"
                                                  Style="{StaticResource BrowserMenuItem}"
                                                  Click="OnBrowserMoveFolder"/>
                                        <MenuItem Tag="CreateFolder"
                                                  Style="{StaticResource BrowserMenuItem}"
                                                  Click="OnBrowserCreateFolder"/>
                                        <MenuItem Tag="RenameFolder"
                                                  Style="{StaticResource BrowserMenuItem}"
                                                  Click="OnBrowserRename"/>
                                        <MenuItem Tag="DeleteFolder"
                                                  Style="{StaticResource BrowserMenuItemDestructive}"
                                                  Click="OnBrowserDeleteFolder"/>

                                        <Separator Tag="SepCheckIndex" Style="{StaticResource BrowserMenuSeparator}"/>

                                        <!-- ── Index diagnostic (always visible) ── -->
                                        <MenuItem Tag="CheckIndex"
                                                  Style="{StaticResource BrowserMenuItem}"
                                                  Click="OnBrowserCheckIndex"/>

                                    </ContextMenu>
                                </ListView.ContextMenu>
                            </ListView>
                        </Grid>
                    </Grid>

                    <!-- Broken-links scanner results panel (row 2, initially collapsed) -->
                    <Border x:Name="BrokenLinksPanel" Grid.Row="2"
                            Background="#0d0d1a" BorderBrush="#E94560" BorderThickness="0,1,0,0"
                            Visibility="Collapsed" MaxHeight="220">
                        <Grid Margin="10,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                <TextBlock x:Name="BrokenLinksStatus"
                                           Foreground="#E94560" FontSize="12" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                                <Button Content="✖" DockPanel.Dock="Right"
                                        Click="OnHideBrokenLinksPanel"
                                        Background="Transparent" Foreground="#888"
                                        BorderThickness="0" Padding="6,2" Cursor="Hand"
                                        ToolTip="Hide this panel"/>
                                <Button Content="🗑️  Delete selected"
                                        Click="OnDeleteBrokenLink"
                                        DockPanel.Dock="Right"
                                        Background="#3a1a1a" Foreground="#E94560"
                                        BorderThickness="0" Padding="8,3" Margin="0,0,6,0"
                                        Cursor="Hand"/>
                            </DockPanel>
                            <ListView x:Name="BrokenLinksList" Grid.Row="1"
                                      Background="Transparent" Foreground="#E94560"
                                      BorderThickness="0" MaxHeight="160">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#E94560"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="Padding" Value="2,2"/>
                                        <Setter Property="ToolTip" Value="{Binding Tooltip}"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Link file" Width="240"
                                                        DisplayMemberBinding="{Binding DisplayName}"/>
                                        <GridViewColumn Header="Stored target" Width="340"
                                                        DisplayMemberBinding="{Binding StoredTarget}"/>
                                        <GridViewColumn Header="In folder" Width="260"
                                                        DisplayMemberBinding="{Binding ParentDir}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ── Idle/QR fullscreen overlay
                 Lives OUTSIDE VideoPanel so the LibVLC HWND is never needed for the QR screen. ── -->
        <Grid x:Name="IdleOverlay"
              Grid.Row="0" Grid.RowSpan="2"
              Background="Black"
              Visibility="Collapsed"
              Panel.ZIndex="50"
              MouseLeftButtonDown="OnIdleOverlayClick">
            <!-- IdleOverlayContent is hidden when audio-only is playing (pure black screen) -->
            <StackPanel x:Name="IdleOverlayContent"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="🎬" FontSize="72" HorizontalAlignment="Center"/>
                <TextBlock Text="RemotePlay" FontSize="32" Foreground="#E94560"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                <TextBlock x:Name="IdleIpText" FontSize="16" Foreground="#AAAAAA"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <Border Background="White" Padding="8" CornerRadius="6" HorizontalAlignment="Center" Margin="0,16,0,0">
                    <Image x:Name="FullscreenQrImage" Width="180" Height="180" Stretch="Uniform"/>
                </Border>
                <TextBlock Text="Scan to open RemotePlay" FontSize="13" Foreground="#AAAAAA"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Karaoke lyrics overlay — shown during music fullscreen when synced lyrics are available -->
            <Grid x:Name="KaraokeLyricsPanel"
                  VerticalAlignment="Center" HorizontalAlignment="Stretch"
                  Margin="48,0"
                  Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="KaraokePrevLine"
                           Grid.Row="0"
                           TextWrapping="Wrap" TextAlignment="Center"
                           FontSize="32" FontWeight="Bold"
                           Foreground="#66FFFFFF"
                           Margin="0,0,0,28"/>
                <TextBlock x:Name="KaraokeActiveLine"
                           Grid.Row="1"
                           TextWrapping="Wrap" TextAlignment="Center"
                           FontSize="72" FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,28">
                    <TextBlock.Effect>
                        <BlurEffect Radius="0"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock x:Name="KaraokeNextLine"
                           Grid.Row="2"
                           TextWrapping="Wrap" TextAlignment="Center"
                           FontSize="32" FontWeight="Bold"
                           Foreground="#66FFFFFF"/>
            </Grid>
        </Grid>

        <!-- ── Video Panel (hidden until actual playback begins) ── -->
        <Grid x:Name="VideoPanel" Grid.Row="0" Grid.RowSpan="2" Visibility="Collapsed" Background="Black"
              MouseMove="OnVideoMouseMove" ClipToBounds="True">
            <vlc:VideoView x:Name="VideoPlayer"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"
                           Visibility="Visible"/>

            <Border x:Name="VideoTransitionOverlay"
                    Background="Black"
                    Visibility="Collapsed"
                    IsHitTestVisible="False"
                    Panel.ZIndex="3"/>

            <Border x:Name="VideoBrightnessOverlay"
                    Background="White"
                    Opacity="0"
                    IsHitTestVisible="False"
                    Panel.ZIndex="1"/>

            <!-- Fullscreen overlay toolbar (auto-hide) — debug access only -->
            <Border x:Name="VideoOverlayToolbar"
                    VerticalAlignment="Top" HorizontalAlignment="Stretch"
                    Background="#CC1a1a2e" Padding="8,6" Opacity="0"
                    Visibility="Collapsed" IsHitTestVisible="False"
                    Panel.ZIndex="10">
                <DockPanel>
                    <TextBlock Text="&#127916; RemotePlay" Foreground="#E94560" FontSize="16"
                               FontWeight="Bold" VerticalAlignment="Center" Margin="4,0,16,0"/>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button Content="&#9003;  Debug" Click="OnToggleView"
                                Background="#333" Foreground="White" BorderThickness="0"
                                Padding="10,4" Margin="4,0" Cursor="Hand"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Transparent hit target that reveals the overlay when the pointer touches the top edge. -->
            <Border x:Name="VideoTopHotZone"
                    VerticalAlignment="Top" HorizontalAlignment="Stretch"
                    Height="18" Background="Transparent"
                    MouseEnter="OnVideoTopHotZoneMouseEnter"
                    Panel.ZIndex="11"/>

            <!-- Now-playing banner -->
            <Border x:Name="NowPlayingBanner"
                    VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                    Background="#AA000000" Padding="24,12" Opacity="0"
                    Panel.ZIndex="9">
                <TextBlock x:Name="NowPlayingText" FontSize="22" Foreground="White"
                           TextTrimming="CharacterEllipsis"/>
            </Border>
        </Grid>

        <!-- ── Flash cover: full-window black mask used to hide resize/render flashes
                 during fullscreen entry. Faded out after the window has settled. ── -->
        <Border x:Name="FlashCover"
                Grid.Row="0" Grid.RowSpan="2"
                Background="Black"
                Visibility="Collapsed"
                IsHitTestVisible="False"
                Panel.ZIndex="100"/>

    </Grid>
</Window>

