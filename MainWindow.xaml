<Window x:Class="RemotePlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="RemotePlay"
        Icon="pack://application:,,,/Assets/RemotePlay.ico"
        Background="#111111"
        WindowStyle="SingleBorderWindow"
        WindowState="Normal"
        Width="900" Height="620"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Tab header style -->
        <Style x:Key="DarkTab" TargetType="TabItem">
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Tab" Background="#1a1a2e" Padding="16,8" Margin="0,0,2,0">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Tab" Property="Background" Value="#0d0d1a"/>
                                <Setter Property="Foreground" Value="#E94560"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Tab" Property="Background" Value="#252540"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#111111">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- toolbar -->
            <RowDefinition Height="*"/>     <!-- content -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar ── -->
        <Border x:Name="AppToolbar" Grid.Row="0" Background="#1a1a2e" Padding="8,6">
            <DockPanel>
                <TextBlock Text="🎬 RemotePlay" Foreground="#E94560" FontSize="16"
                           FontWeight="Bold" VerticalAlignment="Center" Margin="4,0,16,0"/>
                <TextBlock x:Name="ServerStatusText" Foreground="#AAAAAA" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button x:Name="ToggleViewBtn" Content="▶  Switch to Video"
                            Click="OnToggleView"
                            Background="#E94560" Foreground="White" BorderThickness="0"
                            Padding="10,4" Margin="4,0" Cursor="Hand"/>
                    <Button Content="🔄  Refresh Log" Click="OnRefreshLog"
                            Background="#333" Foreground="White" BorderThickness="0"
                            Padding="10,4" Margin="4,0" Cursor="Hand"/>
                    <Button Content="🌐  Test Port" Click="OnTestPort"
                            Background="#333" Foreground="White" BorderThickness="0"
                            Padding="10,4" Margin="4,0" Cursor="Hand"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Tab control (debug mode) ── -->
        <TabControl x:Name="MainTabs" Grid.Row="1"
                    Background="#111111" BorderThickness="0"
                    TabStripPlacement="Top">

            <!-- ── STATUS / LOG tab ── -->
            <TabItem Header="📋  Status" Style="{StaticResource DarkTab}">
                <Grid Background="#111111">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Info bar -->
                    <Border Grid.Row="0" Background="#0d0d1a" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="IpAddressText" Foreground="#00D4AA" FontSize="16"
                                           FontWeight="Bold" TextWrapping="Wrap"/>
                                <TextBlock x:Name="AlternateUrlText" Foreground="#888" FontSize="12"
                                           Margin="0,4,0,0" TextWrapping="Wrap"/>
                                <TextBlock x:Name="MoviesPathText" Foreground="#888" FontSize="11"
                                           Margin="0,4,0,0" TextWrapping="Wrap"/>
                                <TextBlock x:Name="DiagText" Foreground="#FFAA00" FontSize="11"
                                           Margin="0,4,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0" HorizontalAlignment="Right">
                                <Image x:Name="SetupQrImage" Width="112" Height="112" Stretch="Uniform"/>
                                <TextBlock Text="Scan to open" Foreground="#888" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Log output -->
                    <Border Grid.Row="1" Background="#0a0a0a" Margin="8" CornerRadius="4"
                            BorderBrush="#333" BorderThickness="1">
                        <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                            <TextBox x:Name="LogBox"
                                     Background="Transparent" Foreground="#CCCCCC"
                                     FontFamily="Consolas" FontSize="12"
                                     IsReadOnly="True" TextWrapping="Wrap"
                                     BorderThickness="0" Padding="8"
                                     VerticalAlignment="Top"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ── SETTINGS tab ── -->
            <TabItem Header="⚙️  Settings" Style="{StaticResource DarkTab}">
                <ScrollViewer Background="#111111" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,20" MaxWidth="560">

                        <!-- Section: Movies folder -->
                        <TextBlock Text="Movies Folder" Foreground="#E94560"
                                   FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock Foreground="#888" FontSize="11" Margin="0,0,0,12" TextWrapping="Wrap"
                                   Text="The folder (and all subfolders) scanned for video files (.mp4 .mkv .avi .mov .wmv .m4v .ts .flv)."/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="MoviesFolderBox"
                                     Grid.Column="0"
                                     Background="#1e1e2e" Foreground="#EEE"
                                     BorderBrush="#444" BorderThickness="1"
                                     Padding="8,6" FontSize="13"
                                     VerticalContentAlignment="Center"
                                     TextWrapping="NoWrap"/>
                            <Button Grid.Column="1" Content="Browse…"
                                    Click="OnBrowseFolder"
                                    Background="#333" Foreground="White" BorderThickness="0"
                                    Padding="12,6" Margin="8,0,0,0" Cursor="Hand"/>
                        </Grid>

                        <Button Content="Apply &amp; Restart Server"
                                Click="OnApplySettings"
                                Background="#E94560" Foreground="White" BorderThickness="0"
                                Padding="14,8" HorizontalAlignment="Left"
                                Margin="0,8,0,0" Cursor="Hand"/>

                        <TextBlock x:Name="SettingsFeedback" Foreground="#00D4AA"
                                   FontSize="12" Margin="0,10,0,0"
                                   Visibility="Collapsed" TextWrapping="Wrap"/>

                        <!-- Separator -->
                        <Border Background="#333" Height="1" Margin="0,28,0,24"/>

                        <!-- Section: Port -->
                        <TextBlock Text="Web Server Port" Foreground="#E94560"
                                   FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock Foreground="#888" FontSize="11" Margin="0,0,0,12" TextWrapping="Wrap"
                                   Text="Port the web interface listens on. Requires app restart after change."/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="PortBox"
                                     Grid.Column="0"
                                     Background="#1e1e2e" Foreground="#EEE"
                                     BorderBrush="#444" BorderThickness="1"
                                     Padding="8,6" FontSize="13"
                                     VerticalContentAlignment="Center"/>
                            <TextBlock Grid.Column="1" Foreground="#555" FontSize="11"
                                       VerticalAlignment="Center" Margin="12,0,0,0"
                                       Text="(1024–65535)"/>
                        </Grid>

                        <CheckBox x:Name="UseHttpsBox"
                                  Content="Use secure HTTPS web interface"
                                  Foreground="#EEE"
                                  FontSize="13"
                                  Margin="0,8,0,0"/>
                        <TextBlock Foreground="#888" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"
                                   Text="HTTPS helps mobile devices install the site as a PWA. First-time setup may require running RemotePlay as administrator and mobile browsers may ask you to trust the local certificate."/>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Export HTTPS Certificate"
                                    Click="OnExportCertificate"
                                    Background="#333" Foreground="White" BorderThickness="0"
                                    Padding="12,6" Cursor="Hand"/>
                            <Button Content="Open Health Page"
                                    Click="OnOpenHealthPage"
                                    Background="#333" Foreground="White" BorderThickness="0"
                                    Padding="12,6" Margin="8,0,0,0" Cursor="Hand"/>
                        </StackPanel>

                        <Button Content="Apply &amp; Restart Server"
                                Click="OnApplySettings"
                                Background="#555" Foreground="White" BorderThickness="0"
                                Padding="14,8" HorizontalAlignment="Left"
                                Margin="0,8,0,0" Cursor="Hand"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- ── Video Panel (hidden until toggled) ── -->
        <Grid x:Name="VideoPanel" Grid.Row="0" Grid.RowSpan="2" Visibility="Collapsed" Background="Black"
              MouseMove="OnVideoMouseMove">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <vlc:VideoView x:Name="VideoPlayer"
                           Grid.Row="1"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"/>

            <Border x:Name="VideoBrightnessOverlay"
                    Grid.Row="1"
                    Background="White"
                    Opacity="0"
                    IsHitTestVisible="False"
                    Panel.ZIndex="1"/>

            <!-- Idle overlay -->
            <StackPanel x:Name="IdleOverlay"
                        Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Visible"
                        Panel.ZIndex="2">
                <TextBlock Text="🎬" FontSize="72" HorizontalAlignment="Center"/>
                <TextBlock Text="RemotePlay" FontSize="32" Foreground="#E94560"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                <TextBlock x:Name="IdleIpText" FontSize="16" Foreground="#AAAAAA"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <Border Background="White" Padding="8" CornerRadius="6" HorizontalAlignment="Center" Margin="0,16,0,0">
                    <Image x:Name="FullscreenQrImage" Width="180" Height="180" Stretch="Uniform"/>
                </Border>
                <TextBlock Text="Scan to open RemotePlay" FontSize="13" Foreground="#AAAAAA"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Fullscreen overlay toolbar (auto-hide) — debug access only -->
            <Border x:Name="VideoOverlayToolbar"
                    Grid.Row="0"
                    VerticalAlignment="Top" HorizontalAlignment="Stretch"
                    Background="#CC1a1a2e" Padding="8,6" Opacity="0"
                    Visibility="Collapsed" IsHitTestVisible="False"
                    Panel.ZIndex="10">
                <DockPanel>
                    <TextBlock Text="&#127916; RemotePlay" Foreground="#E94560" FontSize="16"
                               FontWeight="Bold" VerticalAlignment="Center" Margin="4,0,16,0"/>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button Content="&#9003;  Debug" Click="OnToggleView"
                                Background="#333" Foreground="White" BorderThickness="0"
                                Padding="10,4" Margin="4,0" Cursor="Hand"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Transparent hit target that reveals the overlay when the pointer touches the top edge. -->
            <Border x:Name="VideoTopHotZone"
                    Grid.Row="0"
                    VerticalAlignment="Top" HorizontalAlignment="Stretch"
                    Height="18" Background="Transparent"
                    MouseEnter="OnVideoTopHotZoneMouseEnter"
                    Panel.ZIndex="11"/>

            <!-- Now-playing banner -->
            <Border x:Name="NowPlayingBanner"
                    Grid.Row="2"
                    VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                    Background="#AA000000" Padding="24,12" Opacity="0">
                <TextBlock x:Name="NowPlayingText" FontSize="22" Foreground="White"
                           TextTrimming="CharacterEllipsis"/>
            </Border>
        </Grid>

    </Grid>
</Window>

