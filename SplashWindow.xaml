<Window x:Class="RemotePlay.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Width="420" Height="260"
        Opacity="0">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.35"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <!-- Outer border with rounded corners and drop shadow -->
    <Border CornerRadius="14"
            Background="#12122A"
            BorderBrush="#2B2B4A"
            BorderThickness="1.5">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="32" ShadowDepth="4" Opacity="0.65"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <!-- Title block -->
            <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,24,0,0">

                <!-- App icon emoji + title on one line -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="🎬" FontSize="32" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="RemotePlay"
                               FontSize="32" FontWeight="Bold"
                               Foreground="#E2E8F0"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock x:Name="VersionText"
                           Text="v2.1.3"
                           FontSize="13"
                           Foreground="#6B7FA8"
                           FontFamily="Segoe UI"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0"/>

                <TextBlock Text="Starting up…"
                           FontSize="12"
                           Foreground="#4A5578"
                           FontFamily="Segoe UI"
                           HorizontalAlignment="Center"
                           Margin="0,14,0,0"/>
            </StackPanel>

            <!-- Animated dot spinner -->
            <StackPanel Grid.Row="1" Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="0,0,0,4">
                <Ellipse x:Name="Dot1" Width="8" Height="8" Fill="#3B82F6" Margin="5,0" Opacity="0.2"/>
                <Ellipse x:Name="Dot2" Width="8" Height="8" Fill="#3B82F6" Margin="5,0" Opacity="0.2"/>
                <Ellipse x:Name="Dot3" Width="8" Height="8" Fill="#3B82F6" Margin="5,0" Opacity="0.2"/>
                <Ellipse x:Name="Dot4" Width="8" Height="8" Fill="#3B82F6" Margin="5,0" Opacity="0.2"/>
                <Ellipse x:Name="Dot5" Width="8" Height="8" Fill="#3B82F6" Margin="5,0" Opacity="0.2"/>

                <StackPanel.Triggers>
                    <EventTrigger RoutedEvent="StackPanel.Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <!-- Dot 1 -->
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot1" Storyboard.TargetProperty="Opacity">
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.0"  Value="0.2"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.2"  Value="1.0"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.5"  Value="0.2"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:1.0"  Value="0.2"/>
                                </DoubleAnimationUsingKeyFrames>
                                <!-- Dot 2 -->
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot2" Storyboard.TargetProperty="Opacity">
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="0.2"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.35" Value="1.0"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.65" Value="0.2"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:1.0"  Value="0.2"/>
                                </DoubleAnimationUsingKeyFrames>
                                <!-- Dot 3 -->
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot3" Storyboard.TargetProperty="Opacity">
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.30" Value="0.2"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.50" Value="1.0"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.80" Value="0.2"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:1.0"  Value="0.2"/>
                                </DoubleAnimationUsingKeyFrames>
                                <!-- Dot 4 -->
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot4" Storyboard.TargetProperty="Opacity">
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.45" Value="0.2"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.65" Value="1.0"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.95" Value="0.2"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:1.0"  Value="0.2"/>
                                </DoubleAnimationUsingKeyFrames>
                                <!-- Dot 5 -->
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot5" Storyboard.TargetProperty="Opacity">
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.60" Value="0.2"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.80" Value="1.0"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:1.10" Value="0.2"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:1.25" Value="0.2"/>
                                </DoubleAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </StackPanel.Triggers>
            </StackPanel>

            <!-- Bottom accent bar -->
            <Border Grid.Row="2" CornerRadius="0,0,14,14" Opacity="0.35">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#3B82F6" Offset="0"/>
                        <GradientStop Color="#8B5CF6" Offset="0.5"/>
                        <GradientStop Color="#E94560" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Grid>
    </Border>
</Window>
