<UserControl x:Class="RemotePlay.Controls.PathListEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <StackPanel>
        <!-- Existing paths list -->
        <ItemsControl x:Name="PathsItemsControl" ItemsSource="{Binding Paths, ElementName=Root}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding ., Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#1e1e2e" Foreground="#EEE"
                                 BorderBrush="#444" BorderThickness="1"
                                 Padding="8,6" FontSize="13"
                                 VerticalContentAlignment="Center"
                                 Tag="{Binding}"
                                 TextChanged="OnPathTextChanged"/>
                        <Button Grid.Column="1" Content="Browse…"
                                Background="#333" Foreground="White" BorderThickness="0"
                                Padding="10,6" Margin="6,0,0,0" Cursor="Hand"
                                Tag="{Binding}"
                                Click="OnBrowsePath"/>
                        <Button Grid.Column="2" Content="✕"
                                Background="#552233" Foreground="#FF6680" BorderThickness="0"
                                Padding="10,6" Margin="4,0,0,0" Cursor="Hand"
                                Tag="{Binding}"
                                Click="OnRemovePath"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Add button -->
        <Button Content="+ Add path" HorizontalAlignment="Left"
                Background="Transparent" Foreground="#E94560"
                BorderBrush="#E94560" BorderThickness="1"
                Padding="10,5" Margin="0,4,0,0" Cursor="Hand"
                Click="OnAddPath"/>
    </StackPanel>
</UserControl>
