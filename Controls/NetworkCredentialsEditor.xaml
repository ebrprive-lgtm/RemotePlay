<UserControl x:Class="RemotePlay.Controls.NetworkCredentialsEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <StackPanel>
        <!-- Existing credential rows -->
        <ItemsControl x:Name="CredentialsItemsControl" ItemsSource="{Binding Entries, ElementName=Root}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,10" Padding="10" Background="#181828"
                            BorderBrush="#2a2a3e" BorderThickness="1" CornerRadius="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <!-- Path row -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Share path"
                                               Foreground="#888" FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#1e1e2e" Foreground="#EEE"
                                             BorderBrush="#444" BorderThickness="1"
                                             Padding="6,5" FontSize="12"
                                             VerticalContentAlignment="Center"
                                             Tag="{Binding}"
                                             TextChanged="OnPathTextChanged"/>
                                    <Button Grid.Column="2" Content="Browse…"
                                            Background="#333" Foreground="White" BorderThickness="0"
                                            Padding="8,5" Margin="6,0,0,0" Cursor="Hand"
                                            Tag="{Binding}"
                                            Click="OnBrowsePath"/>
                                </Grid>
                                <!-- Username row -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Username"
                                               Foreground="#888" FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#1e1e2e" Foreground="#EEE"
                                             BorderBrush="#444" BorderThickness="1"
                                             Padding="6,5" FontSize="12"
                                             VerticalContentAlignment="Center"
                                             Tag="{Binding}"
                                             TextChanged="OnUsernameTextChanged"/>
                                </Grid>
                                <!-- Password row -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Password"
                                               Foreground="#888" FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <PasswordBox Grid.Column="1" x:Name="PasswordField"
                                                 Background="#1e1e2e" Foreground="#EEE"
                                                 BorderBrush="#444" BorderThickness="1"
                                                 Padding="6,5" FontSize="12"
                                                 Tag="{Binding}"
                                                 PasswordChanged="OnPasswordChanged"/>
                                </Grid>
                                <!-- Test button row -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="1" Content="Test Connection"
                                            x:Name="TestButton"
                                            Background="#1a4d2e" Foreground="#4ecca3"
                                            BorderBrush="#2e7d5e" BorderThickness="1"
                                            Padding="8,5" Cursor="Hand"
                                            Tag="{Binding}"
                                            Click="OnTestConnection"/>
                                </Grid>
                            </StackPanel>
                            <!-- Remove button -->
                            <Button Grid.Column="1" Content="✕"
                                    VerticalAlignment="Top"
                                    Background="#552233" Foreground="#FF6680" BorderThickness="0"
                                    Padding="10,6" Cursor="Hand"
                                    Tag="{Binding}"
                                    Click="OnRemoveEntry"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Add button -->
        <Button Content="+ Add network share" HorizontalAlignment="Left"
                Background="Transparent" Foreground="#E94560"
                BorderBrush="#E94560" BorderThickness="1"
                Padding="10,5" Margin="0,4,0,0" Cursor="Hand"
                Click="OnAddEntry"/>
    </StackPanel>
</UserControl>
