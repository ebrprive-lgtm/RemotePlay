<Window x:Class="RemotePlay.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename" SizeToContent="WidthAndHeight"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Topmost="True"
        Background="#111111" Foreground="#CCC"
        MinWidth="380">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="New name:" Foreground="#AAA" FontSize="12" Margin="0,0,0,6"/>

        <TextBox x:Name="NameBox" Grid.Row="1"
                 Background="#1e1e2e" Foreground="#EEE" BorderBrush="#444"
                 BorderThickness="1" Padding="8,6" FontSize="13"
                 Margin="0,0,0,14"
                 KeyDown="OnKeyDown"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" IsDefault="True" Click="OnOk"
                    Background="#E94560" Foreground="White"
                    BorderThickness="0" Padding="18,7" Cursor="Hand" Margin="0,0,8,0"/>
            <Button Content="Cancel" IsCancel="True"
                    Background="#333" Foreground="White"
                    BorderThickness="0" Padding="14,7" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
