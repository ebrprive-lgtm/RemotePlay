<Window x:Class="RemotePlay.FindLinksDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find Links" SizeToContent="Height"
        Width="520" MinWidth="380" MaxHeight="600"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="#111111" Foreground="#CCC">

    <Grid Margin="18,16,18,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="🔎  Find Links" FontSize="15" FontWeight="SemiBold"
                   Foreground="#E94560" Margin="0,0,0,8"/>

        <!-- Target path label -->
        <TextBlock x:Name="TargetLabel" Grid.Row="1"
                   Foreground="#888" FontSize="11"
                   TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                   Margin="0,0,0,14"/>

        <!-- Status / spinner row -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock x:Name="StatusText" FontSize="12" Foreground="#AAA" VerticalAlignment="Center"/>
            <Ellipse x:Name="Spinner" Width="14" Height="14" Margin="8,0,0,0"
                     Fill="#E94560" Visibility="Collapsed" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Results list -->
        <ListView x:Name="ResultsList" Grid.Row="3"
                  Background="#0d0d1a" Foreground="#CCC"
                  BorderBrush="#2a2a3e" BorderThickness="1"
                  MinHeight="60" MaxHeight="320"
                  SelectionMode="Single"
                  Visibility="Collapsed">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#CCC"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="Padding" Value="6,4"/>
                    <Setter Property="ToolTip" Value="{Binding FullPath}"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1a1a3e"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="180">
                        <GridViewColumn.Header>
                            <TextBlock Text="Link name" Foreground="#666" FontSize="11"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontSize="11"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="280">
                        <GridViewColumn.Header>
                            <TextBlock Text="In folder" Foreground="#666" FontSize="11"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Folder}" FontSize="11"
                                           Foreground="#888" TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Close button -->
        <Button Grid.Row="4" Content="Close" IsCancel="True"
                HorizontalAlignment="Right"
                Background="#333" Foreground="White"
                BorderThickness="0" Padding="18,7" Cursor="Hand"
                Margin="0,14,0,0"/>
    </Grid>
</Window>
