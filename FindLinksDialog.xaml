<Window x:Class="RemotePlay.FindLinksDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find Links" SizeToContent="Height"
        Width="680" MinWidth="480" MaxHeight="640"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Topmost="True"
        Background="#111111" Foreground="#CCC">

    <Grid Margin="20,18,20,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="🔎" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="Find Links" FontSize="17" FontWeight="Bold"
                       Foreground="#E94560" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Divider -->
        <Border Grid.Row="1" Height="1" Background="#2a2a3e" Margin="0,0,0,12"/>

        <!-- Target path label -->
        <TextBlock x:Name="TargetLabel" Grid.Row="2"
                   Foreground="#00D4AA" FontSize="11" FontFamily="Consolas"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <!-- Status / spinner row -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock x:Name="StatusText" FontSize="12" FontWeight="SemiBold" Foreground="#AAA" VerticalAlignment="Center"/>
            <Ellipse x:Name="Spinner" Width="12" Height="12" Margin="8,0,0,0"
                     Fill="#E94560" Visibility="Collapsed" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Results panel (header always shown when ResultsPanel is visible) -->
        <Border x:Name="ResultsPanel" Grid.Row="4"
                Background="#0d0d1a" BorderBrush="#2a2a3e" BorderThickness="1"
                CornerRadius="4" Visibility="Collapsed" Margin="0,0,0,0">
            <StackPanel>

                <!-- Column header row -->
                <Border Background="#161628" Padding="10,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="LINK NAME"
                                   Foreground="#555" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="IN FOLDER"
                                   Foreground="#555" FontSize="10" FontWeight="Bold"
                                   Margin="10,0,0,0"/>
                    </Grid>
                </Border>

                <Separator Background="#2a2a3e" Height="1" Margin="0"/>

                <!-- Rows (populated in code-behind via FindName) -->
                <ItemsControl x:Name="ResultsItems">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,7" ToolTip="{Binding FullPath}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1a1a3e"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="3*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               Foreground="#E0E0E0" FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Folder}"
                                               Foreground="#666" FontSize="11" FontFamily="Consolas"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="10,0,0,0"
                                               ToolTip="{Binding Folder}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Close button -->
        <Button Grid.Row="5" Content="Close" IsCancel="True"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Background="#1e1e2e" Foreground="#CCC"
                BorderBrush="#444" BorderThickness="1"
                Padding="20,7" Cursor="Hand"
                Margin="0,14,0,0">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#1e1e2e"/>
                    <Setter Property="Foreground" Value="#CCC"/>
                    <Setter Property="BorderBrush" Value="#444"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Padding" Value="20,7"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="3" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2a2a4e"/>
                            <Setter Property="BorderBrush" Value="#E94560"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>
